{
  "name": "codearts-cli-launcher",
  "displayName": "CodeArts CLI Launcher",
  "description": "Quickly launch CodeArts CLI terminal directly from VS Code with keyboard shortcuts, context-aware file sharing, and seamless terminal integration",
  "version": "1.0.3",
  "publisher": "CyrusRune",
  "repository": {
    "type": "git",
    "url": "https://github.com/CyrusRune/codearts-cli-quick_start-vscode_plugin"
  },
  "license": "MIT",
  "icon": "images/light_icon.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "bugs": {
    "url": "https://github.com/CyrusRune/codearts-cli-quick_start-vscode_plugin/issues"
  },
  "homepage": "https://github.com/CyrusRune/codearts-cli-quick_start-vscode_plugin#readme",
  "keywords": [
    "codearts",
    "ai",
    "code assistant",
    "terminal",
    "coding"
  ],
  "extensionKind": [
    "ui"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codearts.openTerminal",
        "title": "Open CodeArts",
        "icon": {
          "light": "images/light_icon.png",
          "dark": "images/light_icon.png"
        }
      },
      {
        "command": "codearts.openNewTerminal",
        "title": "Open CodeArts in new tab",
        "icon": {
          "light": "images/light_icon.png",
          "dark": "images/light_icon.png"
        }
      },
      {
        "command": "codearts.addFilepathToTerminal",
        "title": "Add Filepath to Terminal"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codearts.openNewTerminal",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codearts.openTerminal",
        "title": "Open CodeArts",
        "key": "cmd+shift+1",
        "mac": "cmd+shift+1",
        "win": "ctrl+shift+1",
        "linux": "ctrl+shift+1"
      },
      {
        "command": "codearts.openNewTerminal",
        "title": "Open CodeArts in new tab",
        "key": "cmd+shift+escape",
        "mac": "cmd+shift+escape",
        "win": "ctrl+shift+escape",
        "linux": "ctrl+shift+escape"
      },
      {
        "command": "codearts.addFilepathToTerminal",
        "title": "CodeArts: Insert At-Mentioned",
        "key": "cmd+shift+2",
        "icon": {
          "light": "images/light_icon.png",
          "dark": "images/light_icon.png"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun run check-types && bun run lint && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
